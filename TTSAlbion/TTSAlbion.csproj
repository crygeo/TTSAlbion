<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFrameworks>net10.0-windows;net9.0-windows</TargetFrameworks>
		<UseWPF>true</UseWPF>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<PlatformTarget>x64</PlatformTarget> 
		<ApplicationManifest>app.manifest</ApplicationManifest>

	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\NetWorkLibrery\NetWorkLibrery.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="Concentus" Version="2.2.2" />
	  <PackageReference Include="Discord.Net" Version="3.19.1" />
	  <PackageReference Include="Newtonsoft.Json" Version="13.0.5-beta1" />
	  <PackageReference Include="PhotonPackageParser" Version="4.1.0" />
	  <PackageReference Include="System.Speech" Version="11.0.0-preview.2.26159.112" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="sample\" />
	</ItemGroup>

	<ItemGroup>
	  <None Update="sample\file.wav">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </None>
	  <None Update="Datos\config.json">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </None>
	</ItemGroup>

</Project>