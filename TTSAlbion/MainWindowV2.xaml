<mah:MetroWindow
    x:Class="TTSAlbion.MainWindowV2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:TTSAlbion.ViewModels"
    xmlns:util="clr-namespace:Utilidades.Converters"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance vm:MainViewModel, IsDesignTimeCreatable=False}"
    Title="TTS Albion"
    Height="680" Width="420"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    TitleCharacterCasing="Normal"
    TitleAlignment="Center"
    ShowTitleBar="True"
    IsWindowDraggable="True"
    TitleBarHeight="32"
    BorderThickness="1"
    BorderBrush="{DynamicResource MahApps.Brushes.Accent}">

    <mah:MetroWindow.Resources>

        <!-- ── Separador de sección con etiqueta ── -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}"/>
            <Setter Property="Margin" Value="0,18,0,6"/>
            <Setter Property="TextDecorations" Value="None"/>
        </Style>

        <!-- ── Panel de grupo (reemplaza md:Card) ── -->
        <Style x:Key="GroupPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray8}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <!-- ── TextBox con línea inferior MahApps ── -->
        <Style x:Key="MetroInputStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource MahApps.Styles.TextBox}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="mah:TextBoxHelper.ClearTextButton" Value="True"/>
        </Style>

        <!-- ── Botón filled accent ── -->
        <Style x:Key="AccentButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MahApps.Styles.Button.Square.Accent}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>

        <!-- ── Botón outline ── -->
        <Style x:Key="OutlineButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MahApps.Styles.Button.Square}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>

        <!-- ── Badge chip ── -->
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}"/>
        </Style>
        <Style x:Key="BadgeStyleOff" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}"/>
        </Style>

        <!-- ── ToggleSwitch MahApps nativo ── -->
        <Style x:Key="FilterToggleStyle"
               TargetType="mah:ToggleSwitch"
               BasedOn="{StaticResource MahApps.Styles.ToggleSwitch}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <!-- ── ComboBox MahApps ── -->
        <Style x:Key="MetroComboStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource MahApps.Styles.ComboBox}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <!-- ── Texto de feedback ── -->
        <Style x:Key="FeedbackTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="2,6,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFeedbackError}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Badged.Background.Error}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Conversor ── -->
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

    </mah:MetroWindow.Resources>

    <!-- Scroll general -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="18,14,18,20">

        <StackPanel>

            <!-- ════════════ JUGADOR ════════════ -->
            <TextBlock Text="JUGADOR" Style="{StaticResource SectionHeaderStyle}"/>

            <Border Style="{StaticResource GroupPanelStyle}">
                <StackPanel>

                    <!-- Fila de estado del jugador -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icono circular -->
                        <Border Width="36" Height="36" CornerRadius="18"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUser}" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <mah:FontIcon Glyph="&#xE77B;" FontSize="16"
                                          Foreground="White"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Nombre + subtítulo -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource MahApps.Brushes.ThemeForeground}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding RegisteredUser}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasUser}" Value="False">
                                                <Setter Property="Text" Value="Sin jugador"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource MahApps.Brushes.Gray3}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="10"
                                       Text="Jugador activo"
                                       Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding HasUser, Converter={StaticResource BoolVis}}"/>
                        </StackPanel>

                        <!-- Badge -->
                        <Border Grid.Column="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                    <Setter Property="Padding" Value="8,3"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUser}" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="9" FontWeight="SemiBold"
                                       Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Activo"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasUser}" Value="False">
                                                <Setter Property="Text" Value="Sin configurar"/>
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource MahApps.Brushes.Gray3}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- Input + botón -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Style="{StaticResource MetroInputStyle}"
                                 mah:TextBoxHelper.Watermark="Nombre del jugador..."
                                 mah:TextBoxHelper.UseFloatingWatermark="True"
                                 Text="{Binding PlayerNameInput, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ApplyUserCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Grid.Column="2"
                                Content="Aplicar"
                                Command="{Binding ApplyUserCommand}"
                                Style="{StaticResource OutlineButtonStyle}"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ════════════ FUENTE DE MENSAJES ════════════ -->
            <TextBlock Text="FUENTE DE MENSAJES" Style="{StaticResource SectionHeaderStyle}"/>

            <Border Style="{StaticResource GroupPanelStyle}">
                <StackPanel>
                    <TextBlock FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource MahApps.Brushes.Gray3}"
                               Margin="0,0,0,10">
                        Selecciona qué eventos de chat activan el TTS.
                    </TextBlock>

                    <StackPanel Orientation="Horizontal">
                        <mah:ToggleSwitch IsOn="{Binding ListenChatMessage}"
                                          OnContent="Chat Message"
                                          OffContent="Chat Message"
                                          Style="{StaticResource FilterToggleStyle}"/>
                        <mah:ToggleSwitch IsOn="{Binding ListenChatSay}"
                                          OnContent="Chat Say  (/say)"
                                          OffContent="Chat Say  (/say)"
                                          Style="{StaticResource FilterToggleStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ════════════ PREFIJO ════════════ -->
            <TextBlock Text="PREFIJO DE COMANDO" Style="{StaticResource SectionHeaderStyle}"/>

            <Border Style="{StaticResource GroupPanelStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Style="{StaticResource MetroInputStyle}"
                             mah:TextBoxHelper.Watermark="Prefijo (ej: !!)"
                             mah:TextBoxHelper.UseFloatingWatermark="True"
                             Text="{Binding PrefixText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ApplyPrefixCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="Aplicar"
                            Command="{Binding ApplyPrefixCommand}"
                            Style="{StaticResource OutlineButtonStyle}"/>
                </Grid>
            </Border>

            <!-- ════════════ SALIDA DE AUDIO ════════════ -->
            <TextBlock Text="SALIDA DE AUDIO" Style="{StaticResource SectionHeaderStyle}"/>

            <Border Style="{StaticResource GroupPanelStyle}">
                <StackPanel>

                    <!-- Selector de sink -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Style="{StaticResource MetroComboStyle}"
                                  mah:TextBoxHelper.Watermark="Tipo de salida"
                                  mah:TextBoxHelper.UseFloatingWatermark="True"
                                  ItemsSource="{Binding SinkOptions}"
                                  SelectedItem="{Binding SelectedSink}"
                                  />

                        <!-- Botón Aplicar: oculto en modo Bot (gestionado con Start/Stop) -->
                        <Button Grid.Column="2"
                                Content="Aplicar"
                                Command="{Binding ApplySinkCommand}"  
                                Style="{StaticResource OutlineButtonStyle}">
                            <Button.Visibility>
                                <Binding Path="IsBotSinkSelected">
                                    <Binding.Converter>
                                        <util:InverseBooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Button.Visibility>
                        </Button>
                            <!-- Inverted via trigger -->
                        
                    </Grid>

                    <!-- Panel Bot — visible sólo cuando DiscordBot seleccionado -->
                    <StackPanel Visibility="{Binding IsBotSinkSelected, Converter={StaticResource BoolVis}}">

                        <Separator Margin="0,0,0,10" Style="{StaticResource MahApps.Styles.Separator.StatusBar}"/>

                        <TextBlock Text="Configuración del Bot"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource MahApps.Brushes.ThemeForeground}"
                                   Margin="0,0,0,8"/>

                        <TextBox Style="{StaticResource MetroInputStyle}"
                                 mah:TextBoxHelper.Watermark="Token del bot"
                                 mah:TextBoxHelper.UseFloatingWatermark="True"
                                 Text="{Binding BotToken, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Style="{StaticResource MetroInputStyle}"
                                     mah:TextBoxHelper.Watermark="Guild ID"
                                     mah:TextBoxHelper.UseFloatingWatermark="True"
                                     Text="{Binding BotGuildId, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBox Grid.Column="2"
                                     Style="{StaticResource MetroInputStyle}"
                                     mah:TextBoxHelper.Watermark="Channel ID"
                                     mah:TextBoxHelper.UseFloatingWatermark="True"
                                     Text="{Binding BotChannelId, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Controles del bot -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Encender Bot"
                                    Command="{Binding StartBotCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Margin="0,0,8,0"/>

                            <Button Content="Apagar Bot"
                                    Command="{Binding StopBotCommand}"
                                    Style="{StaticResource OutlineButtonStyle}"
                                    Margin="0,0,12,0"/>

                            <!-- Indicador de estado -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="{DynamicResource MahApps.Brushes.Gray8}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBotRunning}" Value="True">
                                                    <Setter Property="Fill"
                                                            Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource MahApps.Brushes.Gray3}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Desconectado"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBotRunning}" Value="True">
                                                    <Setter Property="Text" Value="Conectado"/>
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ════════════ TTS MANUAL ════════════ -->
            <TextBlock Text="HABLAR MANUALMENTE" Style="{StaticResource SectionHeaderStyle}"/>

            <Border Style="{StaticResource GroupPanelStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Style="{StaticResource MetroInputStyle}"
                                 mah:TextBoxHelper.Watermark="Texto a vocalizar..."
                                 mah:TextBoxHelper.UseFloatingWatermark="True"
                                 Text="{Binding ManualText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SpeakCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Grid.Column="2"
                                Command="{Binding SpeakCommand}"
                                Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <mah:FontIcon Glyph="&#xE995;" FontSize="13"
                                              VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Hablar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Feedback -->
                    <TextBlock Text="{Binding FeedbackMessage}"
                               Style="{StaticResource FeedbackTextStyle}"
                               TextWrapping="Wrap">
                        
                    </TextBlock>

                </StackPanel>
            </Border>

            <!-- ════════════ PIE ════════════ -->
            <TextBlock Margin="0,16,0,0"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource MahApps.Brushes.Gray5}"
                       Text="TTS Albion · Escucha pasiva de red activa"/>

        </StackPanel>
    </ScrollViewer>
</mah:MetroWindow>
