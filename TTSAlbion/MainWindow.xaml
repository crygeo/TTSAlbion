<mah:MetroWindow
    x:Class="TTSAlbion.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:TTSAlbion.ViewModels"
    xmlns:audio="clr-namespace:TTSAlbion.Services.Audio"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance vm:MainViewModel, IsDesignTimeCreatable=False}"
    Title="TTS Albion"
    Height="720" Width="460"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    TitleCharacterCasing="Normal"
    TitleAlignment="Center"
    Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
    ShowTitleBar="True"
    IsWindowDraggable="True"
    TitleBarHeight="35">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
        <StackPanel MouseLeftButtonDown="UIElement_OnMouseLeftButtonDown">

            <!-- ══ JUGADOR ══ -->
            <TextBlock Text="JUGADOR"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       FontSize="13"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,0,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,0">
                <StackPanel>

                    <!-- Status row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <md:PackIcon Kind="AccountCircle" Width="38" Height="38"
                                     VerticalAlignment="Center" Margin="0,0,12,0">
                            <md:PackIcon.Style>
                                <Style TargetType="md:PackIcon">
                                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUser}" Value="False">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource MahApps.Brushes.SystemControlDisabledBaseLow}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:PackIcon.Style>
                        </md:PackIcon>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="Medium"
                                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding RegisteredUser}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasUser}" Value="False">
                                                <Setter Property="Text" Value="Sin jugador"/>
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource MahApps.Brushes.SystemControlDisabledBaseMediumLow}"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="11" Text="Jugador activo"
                                       Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding HasUser, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <md:Chip Grid.Column="2" VerticalAlignment="Center" IsEnabled="False" FontSize="11">
                            <md:Chip.Style>
                                <Style TargetType="md:Chip" BasedOn="{StaticResource {x:Type md:Chip}}">
                                    <Setter Property="Content" Value="Activo"/>
                                    <Setter Property="Background" Value="{DynamicResource SecondaryHueMidBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUser}" Value="False">
                                            <Setter Property="Content" Value="Sin configurar"/>
                                            <Setter Property="Background"
                                                    Value="{DynamicResource MahApps.Brushes.SystemControlDisabledBaseLow}"/>
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:Chip.Style>
                        </md:Chip>
                    </Grid>

                    <!-- Name input row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox md:HintAssist.Hint="Nombre del jugador..."
                                 md:HintAssist.IsFloating="True"
                                 Text="{Binding PlayerNameInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="13"
                                 Margin="0,0,10,0"
                                 Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ApplyUserCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Grid.Column="1"
                                Content="Aplicar"
                                Command="{Binding ApplyUserCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                md:ButtonAssist.CornerRadius="6"
                                VerticalAlignment="Bottom"
                                Height="40" Padding="14,0"/>
                    </Grid>

                </StackPanel>
            </md:Card>

            <!-- ══ FUENTE DE MENSAJES ══ -->
            <TextBlock Text="FUENTE DE MENSAJES"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       FontSize="13"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,20,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"
                               Margin="0,0,0,12">
                        Selecciona qué eventos de chat desencadenan el TTS.
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox Content="Chat Message  (zona / global)"
                                  IsChecked="{Binding ListenChatMessage}"
                                  FontSize="13"
                                  Margin="0,0,24,0"/>
                        <CheckBox Content="Chat Say  (/say)"
                                  IsChecked="{Binding ListenChatSay}"
                                  FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </md:Card>

            <!-- ══ PREFIJO ══ -->
            <TextBlock Text="PREFIJO DE COMANDO"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       FontSize="13"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,20,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox md:HintAssist.Hint="Prefijo (ej: !!)"
                             md:HintAssist.IsFloating="True"
                             Text="{Binding PrefixText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="13"
                             Margin="0,0,10,0"
                             Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ApplyPrefixCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1"
                            Content="Aplicar"
                            Command="{Binding ApplyPrefixCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            md:ButtonAssist.CornerRadius="6"
                            VerticalAlignment="Bottom"
                            Height="40" Padding="14,0"/>
                </Grid>
            </md:Card>

            <!-- ══ SALIDA DE AUDIO ══ -->
            <TextBlock Text="SALIDA DE AUDIO"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       FontSize="13"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,20,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16">
                <StackPanel>

                    <!-- Sink selector -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox md:HintAssist.Hint="Tipo de salida"
                                  md:HintAssist.IsFloating="True"
                                  ItemsSource="{Binding SinkOptions}"
                                  SelectedItem="{Binding SelectedSink}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  FontSize="13"
                                  Margin="0,0,10,0"/>

                        <Button Grid.Column="1"
                                Content="Aplicar"
                                Command="{Binding ApplySinkCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                md:ButtonAssist.CornerRadius="6"
                                VerticalAlignment="Bottom"
                                Height="40" Padding="14,0"
                                Visibility="{Binding IsBotSinkSelected,
                                    Converter={StaticResource InverseBoolToVisConv}}"/>
                    </Grid>

                    <!-- Bot config panel — visible only when DiscordBot selected -->
                    <StackPanel Visibility="{Binding IsBotSinkSelected,
                                    Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="0,0,0,12"/>

                        <TextBlock Text="Configuración del Bot" FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                   Margin="0,0,0,10"/>

                        <TextBox md:HintAssist.Hint="Token del bot"
                                 md:HintAssist.IsFloating="True"
                                 Text="{Binding BotToken, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="13"
                                 Margin="0,0,0,10"
                                 Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox md:HintAssist.Hint="Guild ID"
                                     md:HintAssist.IsFloating="True"
                                     Text="{Binding BotGuildId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="13"
                                     Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>

                            <TextBox Grid.Column="2"
                                     md:HintAssist.Hint="Channel ID"
                                     md:HintAssist.IsFloating="True"
                                     Text="{Binding BotChannelId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="13"
                                     Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                        </Grid>

                        <!-- Bot start / stop buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Encender Bot"
                                    Command="{Binding StartBotCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    md:ButtonAssist.CornerRadius="6"
                                    Padding="16,0" Height="38"
                                    Margin="0,0,10,0">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="Power" Width="15" Height="15"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Encender Bot" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>

                            <Button Content="Apagar Bot"
                                    Command="{Binding StopBotCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    md:ButtonAssist.CornerRadius="6"
                                    Padding="16,0" Height="38">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="PowerOff" Width="15" Height="15"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Apagar Bot" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>

                            <!-- Bot status indicator -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="{DynamicResource MahApps.Brushes.SystemControlDisabledBaseLow}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBotRunning}" Value="True">
                                                    <Setter Property="Fill"
                                                            Value="{DynamicResource SecondaryHueMidBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Desconectado"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBotRunning}" Value="True">
                                                    <Setter Property="Text" Value="Conectado"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </md:Card>

            <!-- ══ TTS MANUAL ══ -->
            <TextBlock Text="HABLAR MANUALMENTE"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       FontSize="13"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,20,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16">
                <StackPanel>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox md:HintAssist.Hint="Texto a vocalizar..."
                                 md:HintAssist.IsFloating="True"
                                 Text="{Binding ManualText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="13"
                                 Margin="0,0,10,0"
                                 Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SpeakCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Grid.Column="1"
                                Command="{Binding SpeakCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                md:ButtonAssist.CornerRadius="6"
                                VerticalAlignment="Bottom"
                                Height="40" Padding="14,0">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="VolumeHigh" Width="15" Height="15"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Hablar" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </Grid>

                    <!-- Feedback -->
                    <TextBlock Margin="0,10,0,0"
                               FontSize="12"
                               Text="{Binding FeedbackMessage}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FeedbackMessage,
                                        Converter={StaticResource NullToBoolConv}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFeedbackError}" Value="True">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </md:Card>

            <TextBlock Margin="0,16,0,0"
                       FontSize="11" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"
                       Text="TTS Albion · Escucha pasiva de red activa"/>

        </StackPanel>
    </ScrollViewer>
</mah:MetroWindow>
