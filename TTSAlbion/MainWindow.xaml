<mah:MetroWindow
    x:Class="TTSAlbion.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:TTSAlbion.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance vm:MainViewModel, IsDesignTimeCreatable=False}"
    Title="TTS Albion"
    Height="520" Width="440"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    TitleCharacterCasing="Normal"
    TitleAlignment="Center"
    Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="20,16,20,20">
        <StackPanel>

            <!-- ══ Jugador ══ -->
            <TextBlock Text="JUGADOR"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,0,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,0">
                <StackPanel>

                    <!-- Fila avatar + nombre + badge -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar circular -->
                        <md:PackIcon Kind="AccountCircle"
                                     Width="40" Height="40"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0">
                            <md:PackIcon.Style>
                                <Style TargetType="md:PackIcon">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUser}" Value="False">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource MahApps.Brushes.SystemControlDisabledBaseLow}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:PackIcon.Style>
                        </md:PackIcon>

                        <!-- Nombre -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="15" FontWeight="Medium"
                                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding RegisteredUser}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasUser}" Value="False">
                                                <Setter Property="Text" Value="Sin jugador"/>
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource MahApps.Brushes.SystemControlDisabledBaseMediumLow}"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock FontSize="11"
                                       Text="Detectado automáticamente"
                                       Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding HasUser,
                                           Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Chip de estado -->
                        <md:Chip Grid.Column="2"
                                 VerticalAlignment="Center"
                                 IsEnabled="False"
                                 FontSize="11">
                            <md:Chip.Style>
                                <Style TargetType="md:Chip" BasedOn="{StaticResource {x:Type md:Chip}}">
                                    <Setter Property="Content" Value="Activo"/>
                                    <Setter Property="Background"
                                            Value="{DynamicResource SecondaryHueMidBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource SecondaryHueMidForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUser}" Value="False">
                                            <Setter Property="Content" Value="Sin detectar"/>
                                            <Setter Property="Background"
                                                    Value="{DynamicResource MahApps.Brushes.SystemControlDisabledBaseLow}"/>
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:Chip.Style>
                        </md:Chip>
                    </Grid>

                    <!-- Hint cuando no hay usuario -->
                    <md:ColorZone Mode="Dark"
                                  CornerRadius="6"
                                  Padding="10,8"
                                  Margin="0,14,0,0"
                                  Visibility="{Binding HasUser,
                                      Converter={StaticResource InverseBoolToVisConv}}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="InformationOutline"
                                         Width="16" Height="16"
                                         VerticalAlignment="Top"
                                         Margin="0,1,8,0"/>
                            <TextBlock FontSize="12" TextWrapping="Wrap"
                                       MaxWidth="300" LineHeight="18">
                                Abre el panel de estadísticas de tu personaje para localizar tu nombre.
                            </TextBlock>
                        </StackPanel>
                    </md:ColorZone>

                </StackPanel>
            </md:Card>

            <!-- ══ Discord ══ -->
            <TextBlock Text="DISCORD"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,22,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16">
                <StackPanel>

                    <!-- Guild -->
                    <Grid Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Servidor"
                                   FontSize="12"
                                   Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8"
                                     Fill="{DynamicResource SecondaryHueMidBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding GuildName}"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Separator Style="{StaticResource MaterialDesignLightSeparator}"
                               Margin="0,0"/>

                    <!-- Canal de voz -->
                    <Grid Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Canal voz"
                                   FontSize="12"
                                   Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <md:PackIcon Kind="VolumeHigh"
                                         Width="15" Height="15"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"
                                         Foreground="{DynamicResource MahApps.Brushes.AccentBase}"/>
                            <TextBlock Text="{Binding ChannelName}"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </md:Card>

            <!-- ══ TTS Manual ══ -->
            <TextBlock Text="HABLAR MANUALMENTE"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                       Margin="0,22,0,8"/>

            <md:Card UniformCornerRadius="10" Padding="16">
                <StackPanel>

                    <TextBlock FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource MahApps.Brushes.SystemControlPageTextBaseMediumBrush}"
                               Margin="0,0,0,12">
                        Envía texto al canal de voz directamente, sin importar si hay un jugador registrado.
                    </TextBlock>

                    <!-- TextBox con hint -->
                    <TextBox md:HintAssist.Hint="Escribe el texto a vocalizar..."
                             md:HintAssist.IsFloating="True"
                             Text="{Binding ManualText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14"
                             Margin="0,0,0,12">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SpeakCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Botón Hablar -->
                    <Button Content="Hablar"
                            Command="{Binding SpeakCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            md:ButtonAssist.CornerRadius="6"
                            HorizontalAlignment="Right"
                            Padding="20,0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="VolumeHigh"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0"/>
                                    <TextBlock Text="Hablar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!-- Feedback -->
                    <TextBlock Margin="0,10,0,0"
                               FontSize="12"
                               Text="{Binding FeedbackMessage}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SecondaryHueMidBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FeedbackMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding FeedbackMessage}"
                                                       Value="{x:Null}" />
                                        </MultiDataTrigger.Conditions>
                                    </MultiDataTrigger>
                                    <!-- Visible cuando hay mensaje -->
                                    <DataTrigger Binding="{Binding FeedbackMessage,
                                        Converter={StaticResource NullToBoolConv}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <!-- Rojo si es error -->
                                    <DataTrigger Binding="{Binding IsFeedbackError}" Value="True">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </md:Card>

        </StackPanel>
    </ScrollViewer>
</mah:MetroWindow>
